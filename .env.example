# ==================================
# Конфигурация приложения Portal
# ==================================

# Окружение: development, testing, production
APP_ENV=production

# Режим отладки (true/false)
# ВНИМАНИЕ: Отключите в production!
APP_DEBUG=false

# Название приложения
APP_NAME="Корпоративный Портал"

# URL приложения
APP_URL=http://localhost

# ==================================
# База данных
# ==================================

# Путь к SQLite базе данных
DB_PATH=data/portal.db

# Пул PRAGMA настройки (разделенные запятыми)
DB_PRAGMAS=foreign_keys=ON,journal_mode=WAL,synchronous=NORMAL

# ==================================
# Безопасность
# ==================================

# Секретный ключ приложения (сгенерируйте случайную строку!)
# Можно сгенерировать: openssl rand -hex 32
APP_KEY=change-this-to-random-64-character-string-for-security

# CSRF защита (true/false)
SECURITY_CSRF_ENABLED=true

# Максимальный размер загружаемых файлов (в мегабайтах)
SECURITY_MAX_UPLOAD_SIZE=10

# Разрешенные расширения файлов (разделенные запятыми)
SECURITY_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,csv,txt

# ==================================
# Сессии
# ==================================

# Время жизни сессии (в секундах, 3600 = 1 час)
SESSION_LIFETIME=7200

# Имя сессии
SESSION_NAME=PORTAL_SESSION

# Строгий режим сессии (true/false)
SESSION_STRICT=true

# ==================================
# Логирование
# ==================================

# Уровень логирования: debug, info, warning, error
LOG_LEVEL=info

# Путь к директории логов
LOG_PATH=logs

# Максимальный размер файла лога (в мегабайтах)
LOG_MAX_SIZE=10

# Количество хранимых файлов логов
LOG_MAX_FILES=30

# ==================================
# Кэширование
# ==================================

# Включить кэширование (true/false)
CACHE_ENABLED=true

# Время жизни кэша по умолчанию (в секундах)
CACHE_DEFAULT_TTL=300

# Путь к директории кэша
CACHE_PATH=cache

# ==================================
# Загрузки файлов
# ==================================

# Путь к директории загрузок
UPLOAD_PATH=uploads

# Путь к временным файлам
UPLOAD_TEMP_PATH=uploads/temp

# ==================================
# Email (если планируется)
# ==================================

MAIL_ENABLED=false
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="Portal"

# ==================================
# Дополнительные настройки
# ==================================

# Часовой пояс
APP_TIMEZONE=Europe/Moscow

# Язык по умолчанию
APP_LOCALE=ru

# Кодировка
APP_CHARSET=UTF-8

# Режим обслуживания (true/false)
MAINTENANCE_MODE=false

# ==================================
# Примечания
# ==================================
# 
# 1. Копируйте этот файл в .env: cp .env.example .env
# 2. Обязательно измените APP_KEY!
# 3. Не загружайте .env в репозиторий!
# 4. В production установите APP_DEBUG=false
# 5. Для генерации APP_KEY: openssl rand -hex 32
