# Environment Configuration
# Скопируйте этот файл в .env и настройте под свою среду

# Application
APP_ENV=production
APP_DEBUG=false
APP_NAME="Корпоративный Портал"
APP_URL=http://localhost

# Database
DB_TYPE=sqlite
DB_PATH=data/portal.db

# Security
SESSION_LIFETIME=7200
CSRF_TOKEN_NAME=csrf_token
PASSWORD_MIN_LENGTH=8

# Cache
CACHE_ENABLED=true
CACHE_TTL=300
CACHE_DIR=cache

# Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=csv,txt,pdf,doc,docx,xls,xlsx
UPLOAD_DIR=uploads

# Logging
LOG_ENABLED=true
LOG_LEVEL=error
LOG_DIR=logs

# Email (для будущих уведомлений)
MAIL_ENABLED=false
MAIL_FROM=noreply@portal.local
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=
MAIL_SMTP_PASS=
